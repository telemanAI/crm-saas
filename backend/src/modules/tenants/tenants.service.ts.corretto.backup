import { Injectable, ConflictException } from '@nestjs/common';
import { InjectRepository } from '@nestjs/typeorm';
import { Repository } from 'typeorm';
import * as bcrypt from 'bcrypt';
import { Tenant } from '../../entities/tenant.entity';
import { User } from '../../entities/user.entity';

interface RegisterTenantDto {
  businessName: string;
  vatNumber: string;
  phone: string;
  email: string;
  addressLine1: string;
  addressLine2?: string;
  city: string;
  province: string;
  postalCode: string;
  adminFirstName: string;
  adminLastName: string;
  adminEmail: string;
  adminPassword: string;
}

@Injectable()
export class TenantsService {
  constructor(
    @InjectRepository(Tenant)
    private tenantRepository: Repository<Tenant>,
    @InjectRepository(User)
    private userRepository: Repository<User>,
  ) {}

  private generateSubscriptionCode(): string {
    const prefix = 'NEG';
    const random = Math.floor(1000 + Math.random() * 9000);
    return `${prefix}${random}`;
  }

  async register(registerDto: RegisterTenantDto) {
    const existingVat = await this.tenantRepository.findOne({
      where: { vatNumber: registerDto.vatNumber },
    });

    if (existingVat) {
      throw new ConflictException('Partita IVA già registrata');
    }

    const existingEmail = await this.userRepository.findOne({
      where: { email: registerDto.adminEmail },
    });

    if (existingEmail) {
      throw new ConflictException('Email admin già in uso');
    }

    let subscriptionCode = this.generateSubscriptionCode();
    let existingCode = await this.tenantRepository.findOne({
      where: { subscriptionCode },
    });

    while (existingCode) {
      subscriptionCode = this.generateSubscriptionCode();
      existingCode = await this.tenantRepository.findOne({
        where: { subscriptionCode },
      });
    }

    const tenant = this.tenantRepository.create({
      businessName: registerDto.businessName,
      vatNumber: registerDto.vatNumber,
      subscriptionCode,
      phone: registerDto.phone,
      email: registerDto.email,
      addressLine1: registerDto.addressLine1,
      addressLine2: registerDto.addressLine2 || null,
      city: registerDto.city,
      province: registerDto.province.toUpperCase(),
      postalCode: registerDto.postalCode,
      isActive: true,
    });

    const savedTenant = await this.tenantRepository.save(tenant);

    const passwordHash = await bcrypt.hash(registerDto.adminPassword, 10);

    const admin = this.userRepository.create({
      tenantId: savedTenant.id,
      email: registerDto.adminEmail,
      passwordHash,
      firstName: registerDto.adminFirstName,
      lastName: registerDto.adminLastName,
      role: 'ADMIN',
      isActive: true,
    });

    await this.userRepository.save(admin);

    return {
      message: 'Negozio registrato con successo',
      tenant: {
        id: savedTenant.id,
        businessName: savedTenant.businessName,
        subscriptionCode: savedTenant.subscriptionCode,
      },
      admin: {
        email: admin.email,
        firstName: admin.firstName,
        lastName: admin.lastName,
      },
    };
  }

  async findBySubscriptionCode(subscriptionCode: string): Promise<Tenant | null> {
    return this.tenantRepository.findOne({
      where: { subscriptionCode },
    });
  }

  async findById(id: string): Promise<Tenant | null> {
    return this.tenantRepository.findOne({
      where: { id },
    });
  }

  async findAll(): Promise<Tenant[]> {
    return this.tenantRepository.find({
      order: { createdAt: 'DESC' },
    });
  }
}
