# ================================================================
# BACKEND ENV — TELEMANAI CRM v2
# ================================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=crm
DB_PASSWORD=crm_password
DB_NAME=crm_db

# --- JWT ---
JWT_SECRET=change-me-in-production-very-long-random-string

# --- Redis (BullMQ, rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- Frontend URL (per redirect OAuth + invite link) ---
FRONTEND_URL=http://localhost:3000
# Produzione: https://www.telemanai.it

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=noreply@telemanai.it

# --- Google OAuth 2.0 ---
# REMINDER: DO NOT HARDCODE THE URL, OR ADD ANY FALLBACKS OR REDIRECT URLS, THIS BREAKS THE AUTH
# Configura gli Authorized redirect URIs in https://console.cloud.google.com
# Sviluppo:    http://localhost:3001/api/auth/google/callback
# Produzione:  https://backend-production-316a.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# --- Facebook OAuth (opzionale — lasciare vuoto se non ancora configurato) ---
# Valid OAuth Redirect URIs in https://developers.facebook.com:
# Sviluppo:    http://localhost:3001/api/auth/facebook/callback
# Produzione:  https://backend-production-316a.up.railway.app/api/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,https://www.telemanai.it

# --- Environment ---
NODE_ENV=development
PORT=3001
TYPEORM_SYNC=false

# --- Google Places (esistente) ---
GOOGLE_PLACES_API_KEY=
