import { 
  Controller, 
  Get, 
  Param, 
  Put, 
  Delete, 
  Body, 
  UseGuards, 
  Query,
  ParseUUIDPipe,
  ParseEnumPipe,
  HttpCode,
  HttpStatus
} from '@nestjs/common';
import { TenantsService } from './tenants.service';
import { JwtAuthGuard } from '../auth/jwt-auth.guard';
import { RolesGuard } from '../auth/guards/roles.guard';
import { Roles } from '../auth/decorators/roles.decorator';
import { UpdateTenantAdminDto, TenantPlanType } from './dto/update-tenant-admin.dto';

@Controller('api/admin/tenants')
@UseGuards(JwtAuthGuard, RolesGuard)
@Roles('SUPER_ADMIN')
export class AdminTenantsController {
  constructor(private readonly tenantsService: TenantsService) {}

  /**
   * Lista tutti i negozi con statistiche aggregate
   * GET /api/admin/tenants?status=active&plan=basic&page=1&limit=20
   */
  @Get()
  async findAll(
    @Query('status') status?: 'active' | 'inactive' | 'suspended' | 'trial',
    @Query('plan') plan?: string,
    @Query('search') search?: string,
    @Query('page') page: number = 1,
    @Query('limit') limit: number = 20,
  ) {
    return this.tenantsService.findAllForAdmin({
      status,
      plan,
      search,
      page: Number(page),
      limit: Number(limit),
    });
  }

  /**
   * Statistiche globali dashboard
   * GET /api/admin/stats
   */
  @Get('stats/global')
  async getGlobalStats() {
    return this.tenantsService.getGlobalStats();
  }

  /**
   * Dettaglio completo singolo negozio
   * GET /api/admin/tenants/:id
   */
  @Get(':id')
  async findOne(@Param('id', ParseUUIDPipe) id: string) {
    return this.tenantsService.getTenantDetailsWithStats(id);
  }

  /**
   * Aggiorna stato negozio (active/inactive/suspended)
   * PUT /api/admin/tenants/:id/status
   */
  @Put(':id/status')
  @HttpCode(HttpStatus.OK)
  async updateStatus(
    @Param('id', ParseUUIDPipe) id: string,
    @Body('status') status: 'active' | 'inactive' | 'suspended',
    @Body('reason') reason?: string,
  ) {
    return this.tenantsService.updateTenantStatus(id, status, reason);
  }

  /**
   * Cambia piano abbonamento
   * PUT /api/admin/tenants/:id/plan
   */
  @Put(':id/plan')
  @HttpCode(HttpStatus.OK)
  async updatePlan(
    @Param('id', ParseUUIDPipe) id: string,
    @Body() updatePlanDto: UpdateTenantAdminDto,
  ) {
    return this.tenantsService.updateTenantPlan(id, updatePlanDto);
  }

  /**
   * Soft-delete negozio (archivia)
   * DELETE /api/admin/tenants/:id
   */
  @Delete(':id')
  @HttpCode(HttpStatus.NO_CONTENT)
  async remove(@Param('id', ParseUUIDPipe) id: string) {
    return this.tenantsService.softDeleteTenant(id);
  }

  /**
   * Lista utenti di un specifico negozio
   * GET /api/admin/tenants/:id/users
   */
  @Get(':id/users')
  async getTenantUsers(
    @Param('id', ParseUUIDPipe) id: string,
    @Query('page') page: number = 1,
    @Query('limit') limit: number = 50,
  ) {
    return this.tenantsService.getTenantUsers(id, Number(page), Number(limit));
  }

  /**
   * Lista clienti di un specifico negozio
   * GET /api/admin/tenants/:id/customers
   */
  @Get(':id/customers')
  async getTenantCustomers(
    @Param('id', ParseUUIDPipe) id: string,
    @Query('page') page: number = 1,
    @Query('limit') limit: number = 50,
  ) {
    return this.tenantsService.getTenantCustomers(id, Number(page), Number(limit));
  }
}